@page
@model SM.APP.Pages.Classes.ClassOccurancesModel
@{
    ViewData["Title"] = "Class Occurences";
}
<div class="container py-4">
    <div class="mb-5">
        <div class="d-flex align-items-center mb-3 text-primary"
             data-bs-toggle="collapse"
             data-bs-target="#todayClasses"
             role="button"
             aria-expanded="true">
            <i class="bi bi-calendar-check-fill me-2"></i>
            <h4 class="mb-0 fw-bold">Today's Classes</h4>
            <div class="flex-grow-1 ms-3 border-bottom border-primary border-opacity-25 d-none d-sm-block"></div>
            <i class="bi bi-chevron-down ms-2"></i>
        </div>

        <div id="todayClasses" class="collapse show">
            <div class="row g-3">
                @if (Model.TodayClasses.Any())
                {
                    @foreach (var item in Model.TodayClasses)
                    {
                        <div class="col-12 col-md-6 col-lg-4">
                            <div class="card h-100 border shadow-sm border-0 border-start border-4 border-primary">
                                <div class="card-body d-flex flex-column p-4">
                                    <div class="mb-3">
                                        <h5 class="card-title fw-bold mb-1">@Html.DisplayFor(modelItem => item.ClassOccurrenceName)</h5>
                                        <small class="text-primary fw-semibold">Scheduled for Today</small>
                                    </div>
                                    <div class="mt-auto">
                                        <a asp-page="./TakeAttendance"
                                           asp-route-classOccurenceID="@item.ClassOccurrenceID"
                                           class="btn btn-primary w-100 rounded-3 shadow-sm">
                                            <i class="bi bi-person-check me-2"></i>Take Attendance
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12">
                        <div class="bg-light rounded-3 p-5 text-center border border-2 border-secondary border-opacity-10">
                            <i class="bi bi-calendar-x text-muted fs-1"></i>
                            <p class="text-muted mt-2 mb-0">No meetings scheduled for today.</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div>
        <div class="d-flex align-items-center mb-3 text-dark"
             data-bs-toggle="collapse"
             data-bs-target="#pastClasses"
             role="button"
             aria-expanded="false">
            <i class="bi bi-clock-history me-2"></i>
            <h4 class="mb-0 fw-bold">Past Classes</h4>
            <div class="flex-grow-1 ms-3 border-bottom border-dark border-opacity-10 d-none d-sm-block"></div>
            <i class="bi bi-chevron-down ms-2"></i>
        </div>

        <div id="pastClasses" class="collapse">
            <div class="row g-3">
                @foreach (var item in Model.PastClasses)
                {
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="card h-100 border shadow-sm border-0 border-start border-4 border-dark">
                            <div class="card-body d-flex flex-column p-4">
                                <div class="mb-3">
                                    <h5 class="card-title fw-bold mb-1">@Html.DisplayFor(modelItem => item.ClassOccurrenceName)</h5>
                                    <small class="text-muted">Completed Session</small>
                                </div>
                                <div class="mt-auto">
                                    <a asp-page="./TakeAttendance"
                                       asp-route-classOccurenceID="@item.ClassOccurrenceID"
                                       class="btn btn-outline-dark w-100 rounded-3">
                                        Edit Attendance
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
